{
  "name": "vintest",
  "version": "0.1.0",
  "description": "Run the same tests under multiple Node.js versions (Playwright-style matrix)",
  "type": "module",
  "bin": {
    "vintest": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test:self": "node --test dist/**/*.test.js",
    "vintest": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "node",
    "testing",
    "matrix",
    "multi-version"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "^5.8.3"
  }
}
